# Roboflow object detection (https://app.roboflow.com/settings/api)
ROBOFLOW_API_KEY=your_api_key_here
# Your custom trained model (workspace/project/version) — NOT yolov8s-640 (generic COCO)
ROBOFLOW_MODEL_ID=your-workspace/black-cube-gripper/1
ROBOFLOW_CONFIDENCE=0.25
ROBOFLOW_API_URL=https://serverless.roboflow.com
# Optional legacy allow-list (leave empty to use OBJECT + GRIPPER classes below)
ROBOFLOW_CLASS_FILTER=
# Classes treated as pick targets (black cube on the board)
ROBOFLOW_OBJECT_CLASSES=block,cube,black_cube
# Classes treated as the gripper origin (yellow tape on the arm)
ROBOFLOW_GRIPPER_CLASSES=gripper_tip,yellow_tape,gripper

# Station camera detection: roboflow, auto (roboflow then contrast), or contrast
NORMA_VISION_BACKEND=roboflow

# Browser overlay: use local yellow-tape + black-cube detection (recommended)
# Set to roboflow only when using a custom trained Roboflow model with detections
# VITE_VISION_PREFER_REMOTE=roboflow

# Manual workspace was calibrated on this stream size (width,height)
NORMA_WORKSPACE_REF_SIZE=299,224

# Local YOLO fallback (optional)
NORMA_VISION_MODEL=yolov8s-worldv2.pt
